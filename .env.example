# =============================================================================
# Folio — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] enable specific features but are not critical.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Auth & Database
# -----------------------------------------------------------------------------

# [REQUIRED] Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Supabase anonymous/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# [REQUIRED] Supabase service role key (server-side only, never expose)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# [REQUIRED] Direct Postgres connection string for Drizzle ORM
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Cloudflare R2 — Asset Storage
# -----------------------------------------------------------------------------

# [REQUIRED] Cloudflare account ID (from `npx wrangler whoami`)
R2_ACCOUNT_ID=your-cloudflare-account-id

# [REQUIRED] R2 API token — access key ID
R2_ACCESS_KEY_ID=your-r2-access-key-id

# [REQUIRED] R2 API token — secret access key
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# [REQUIRED] R2 bucket name
R2_BUCKET_NAME=folio-assets

# [REQUIRED] Public URL for the R2 bucket (custom domain or r2.dev URL)
R2_PUBLIC_URL=https://assets.yourdomain.com

# -----------------------------------------------------------------------------
# PartyKit — Realtime Collaboration (Yjs)
# -----------------------------------------------------------------------------

# [REQUIRED] PartyKit host URL (output of `npx partykit deploy`)
NEXT_PUBLIC_PARTYKIT_HOST=your-project.partykit.dev

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# [REQUIRED] Public URL of the deployed app (no trailing slash)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# [OPTIONAL] Email address for admin-only API routes
ADMIN_EMAIL=admin@yourdomain.com

# [OPTIONAL] Secret token to authenticate cron job requests
CRON_SECRET=a-random-secret-string

# -----------------------------------------------------------------------------
# Stripe — Payments & Subscriptions
# -----------------------------------------------------------------------------

# [OPTIONAL] Stripe publishable key (client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# [OPTIONAL] Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_live_...

# [OPTIONAL] Stripe webhook signing secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# [OPTIONAL] Stripe Price IDs for each plan tier
STRIPE_PRICE_CREATOR_MONTHLY=price_...
STRIPE_PRICE_CREATOR_ANNUAL=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...
STRIPE_PRICE_STUDIO_ANNUAL=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_ANNUAL=price_...

# -----------------------------------------------------------------------------
# Upstash Redis — Rate Limiting
# -----------------------------------------------------------------------------

# [OPTIONAL] Falls back to in-memory rate limiting if not set
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# -----------------------------------------------------------------------------
# Resend — Transactional Email
# -----------------------------------------------------------------------------

# [OPTIONAL] Resend API key for sending emails
RESEND_API_KEY=re_...

# [OPTIONAL] Sender address (must be from a verified domain in Resend)
EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Anthropic — AI Features (translate, generate, notes)
# -----------------------------------------------------------------------------

# [OPTIONAL] Anthropic API key for AI-powered features
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Unsplash — Stock Photos
# -----------------------------------------------------------------------------

# [OPTIONAL] Unsplash API access key for image search
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# -----------------------------------------------------------------------------
# Sentry — Error Monitoring
# -----------------------------------------------------------------------------

# [OPTIONAL] Sentry DSN for error reporting (client + server)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# [OPTIONAL] Sentry organization slug (for source map uploads at build time)
SENTRY_ORG=your-sentry-org

# [OPTIONAL] Sentry project slug
SENTRY_PROJECT=folio

# -----------------------------------------------------------------------------
# PostHog — Product Analytics
# -----------------------------------------------------------------------------

# [OPTIONAL] PostHog project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# [OPTIONAL] PostHog host (defaults to https://us.i.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
